WORKHUB_ENV=production
WORKHUB_HOST=127.0.0.1
WORKHUB_PORT=8770

WORKHUB_DATA_DIR=/opt/workhub/data
WORKHUB_BACKUP_DIR=/opt/workhub/backups

WORKHUB_COOKIE_SECURE=true
WORKHUB_COOKIE_SAMESITE=Lax
WORKHUB_SESSION_SECONDS=43200
WORKHUB_SESSION_IDLE_SECONDS=7200

WORKHUB_SECRET_KEY=replace-with-a-long-random-secret

WORKHUB_INITIAL_ADMIN_USERNAME=
WORKHUB_INITIAL_ADMIN_NAME=
WORKHUB_INITIAL_ADMIN_PASSWORD=

HERMES_ENABLED=false
HERMES_PROFILE=vps
HERMES_BASE_URL=http://hermes-agent:4871
HERMES_HEALTH_PATH=/health
HERMES_CHAT_PATH=/api/chat
HERMES_AUTOMATION_PATH=/api/automation
# Keep this as hermes/shared to route search and image requests through Hermes.
# Set to openai only when direct OpenAI API billing is intentionally enabled.
WORKHUB_AI_TOOL_PROVIDER=hermes

WORKHUB_LOG_LEVEL=INFO
